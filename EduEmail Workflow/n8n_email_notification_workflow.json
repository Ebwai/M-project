    {
      "parameters": {
        "jsCode": "const newItems = [];\n\nfor (const item of $input.all()) {\n  let hasImage = false;\n  let targetImage = null;\n\n  // 检查是否有图片附件\n  if (item.binary) {\n    for (const key of Object.keys(item.binary)) {\n      const file = item.binary[key];\n      if (file.mimeType && file.mimeType.startsWith('image/')) {\n        hasImage = true;\n        targetImage = file;\n        break; // 找到第一张图就停止\n      }\n    }\n  }\n\n  // 无论有没有图片，都把邮件放行，但打上不同的标签\n  if (hasImage) {\n    newItems.push({\n      json: { ...item.json, has_image: true },\n      binary: { target_image: targetImage } // 准备好图片给 AI\n    });\n  } else {\n    newItems.push({\n      json: { ...item.json, has_image: false },\n      binary: item.binary // 保持原样\n    });\n  }\n}\n\nreturn newItems;"
      },
