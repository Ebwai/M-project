      "parameters": {
        "schemaType": "manual",
        "inputSchema": "={\n  \"type\": \"object\",\n  \"properties\": {\n    \"originalSender\": {\n      \"type\": \"string\",\n      \"description\": \"提取真正的发件人邮箱。如果正文中包含 From: xxx@yy.com 或发件人: xxx 等转发记录，提取该原始邮箱；若实在找不到，填表面发件人\"\n    },\n    \"isPersonalOrCompany\": {\n      \"type\": \"boolean\",\n      \"description\": \"发件人是否是个人或外部公司？(需要你通过发件人的邮件名进行判断是不是个人邮箱或者是公司邮箱，是的话填true；请注意对于cuhk后缀且名字像机构的邮箱如 curecruit@cuhk.edu.hk,artmuseumnews@cuhk.edu.hk,cumassmailing@cuhk.edu.hk,gip@cuhk.edu.hk,do_not_reply@cuhk.edu.hk,cpdc@cuhk.edu.hk,enf-pip@cuhk.edu.hk,lces@cuhk.edu.hk,SEDS@cuhk.edu.hk,leos@cuhk.edu.hk,do_not_reply@cuhk.edu.hk,student-election@cuhk.edu.hk,engineering@cuhk.edu.hk,mpss@cuhk.edu.hk,info@newsletter.cuhk.edu.hk填false)\"\n    },\n    \"isImportantAcademicOrFee\": {\n      \"type\": \"boolean\",\n      \"description\": \"【核心学业属性】是否涉及交学费、交学杂费（注意：普通活动的报名费不算）、交作业、或者与考试（Exam/Test/Midterm/Final）直接相关的话题？\"\n    },\n    \"hasDeadline\": {\n      \"type\": \"boolean\",\n      \"description\": \"是否包含截止时间/日期？，比如“明天来我办公室”这种表达也算是包含截止时间\"\n    },\n    \"isActivity\": {\n      \"type\": \"boolean\",\n      \"description\": \"是否是关于讲座、研讨会、学生活动、比赛的？\"\n    },\n    \"isEngineeringOrEE\": {\n      \"type\": \"boolean\",\n      \"description\": \"如果是活动，是否和工程学院(Engineering)或电子工程(EE)相关？\"\n    },\n    \"hasGiveaway\": {\n      \"type\": \"boolean\",\n      \"description\": \"是否提到有免费赠品、抽奖、纪念品(souvenir/gift)？\"\n    },\n    \"isJobHunting\": {\n      \"type\": \"boolean\",\n      \"description\": \"是否关于求职、招聘或职场发展的？(【核心强制触发词】：实习/Internship、招聘/Hiring/Recruitment、宣讲会/Recruitment Talk、职位/Job、管培生/MT/Graduate Program、面试/笔试、简历/CV、Career等。只要涉及公司提供工作机会，哪怕标题是讲座也必须填 true)\"\n    },\n    \"prefEmbedded\": {\n      \"type\": \"boolean\",\n      \"description\": \"是否与嵌入式有联系？\"\n    },\n    \"prefBigTech\": {\n      \"type\": \"boolean\",\n      \"description\": \"是否提到知名科技大公司(如Google,腾讯,华为等大厂)？\"\n    },\n    \"prefEntertainment\": {\n      \"type\": \"boolean\",\n      \"description\": \"是否提到古典乐、[... 1838 chars omitted ...]"      },
